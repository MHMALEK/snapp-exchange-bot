# Telegram: create a bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Local SQLite (default): sqlite+aiosqlite:///./data/app.db
# Free Postgres (Neon, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Optional: API base URL if the bot should call the HTTP API (same machine example)
# API_BASE_URL=http://127.0.0.1:8000

# User-visible copy: exchange_money_bot/locales/fa.py (add locales/en.py later).
# Default language: DEFAULT_LOCALE in exchange_money_bot/constants.py.

# Listings channel: bot must be channel admin (post + edit its messages).
# Chat id: @public_username or -100xxxxxxxxxx (with @username, «open channel» can use https://t.me/…)
# TELEGRAM_LISTINGS_CHANNEL_ID=@your_listings_channel

# Optional membership gate: only members of this chat can use /start and the rest of the bot.
# If unset but listings channel is set, membership is checked against the listings channel.
# TELEGRAM_MEMBERSHIP_CHANNEL_ID=
# TELEGRAM_ENFORCE_CHANNEL_MEMBERSHIP=true

# Invite/public link for "join channel" / "open channel" buttons (e.g. https://t.me/+invite)
# TELEGRAM_CHANNEL_INVITE_URL=https://t.me/your_listings_channel
