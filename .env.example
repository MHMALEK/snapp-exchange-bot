# Telegram: create a bot via @BotFather
TELEGRAM_BOT_TOKEN=

# Local SQLite (default): sqlite+aiosqlite:///./data/app.db
# Free Postgres (Neon, Supabase, etc.):
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:5432/postgres

DATABASE_URL=sqlite+aiosqlite:///./data/app.db

# Optional: API base URL if the bot should call the HTTP API (same machine example)
# API_BASE_URL=http://127.0.0.1:8000

# User-visible copy: exchange_money_bot/locales/fa.py (add locales/en.py later).
# Default language: DEFAULT_LOCALE in exchange_money_bot/constants.py.

# Same channel for listings and membership: bot must be admin (post + edit). Users must stay in the channel to use the bot.
# Chat id: @public_username or -100xxxxxxxxxx. With numeric id, the bot resolves invite/username via API when possible.
# TELEGRAM_LISTINGS_CHANNEL_ID=-100xxxxxxxxxx

# Optional: different chat for membership checks only (rare). Defaults to listings channel.
# TELEGRAM_MEMBERSHIP_CHANNEL_ID=

# Local/dev: set to true to allow using the bot without joining the channel (do not use in production).
# TELEGRAM_DISABLE_MEMBERSHIP_GATE=false

# Optional explicit URL for «join» / «open channel» (e.g. https://t.me/+invite). Overrides API resolution when set.
# TELEGRAM_CHANNEL_INVITE_URL=

# USD/EUR → rial snapshot for the «نرخ زنده و معادل ریالی» menu (margani/pricedb TGJU JSON by default).
# IRR_RATES_TTL_SECONDS=300
# IRR_USD_JSON_URL=
# IRR_EUR_JSON_URL=
